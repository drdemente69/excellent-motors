# ─────────────────────────────────────────────────────────────────────────────
# Excellent Motors — environment template. Copy to `.env` and fill in.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# Local (Homebrew):  postgresql://<youruser>@localhost:5432/excellent_motors?schema=public
# Docker compose:    postgresql://postgres:postgres@localhost:5432/excellent_motors?schema=public
# Vercel + Neon:     use the POOLED connection string here (…-pooler.…).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/excellent_motors?schema=public"

# Direct (non-pooled) connection — used only for `prisma migrate`.
# Local: same as DATABASE_URL. Vercel + Neon: the NON-pooled string.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/excellent_motors?schema=public"

# Auth.js v5 — generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="change-me-to-a-32-byte-random-string"
AUTH_TRUST_HOST=true
NEXTAUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_BUSINESS_NAME="Excellent Motors"

# Payments — swappable PaymentProvider. Options: mock | jazzcash | easypaisa | card
# "mock" is a fully working test provider; COD & in-store pickup need no gateway.
PAYMENT_PROVIDER="mock"

# Email/notifications — Options: console | smtp | resend
# "console" prints emails to the server log in dev.
EMAIL_PROVIDER="console"
EMAIL_FROM="orders@excellentmotors.pk"
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# RESEND_API_KEY=

# File storage — Options: local | s3   (local writes to /public/uploads)
STORAGE_PROVIDER="local"
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
